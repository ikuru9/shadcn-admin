{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "keybinds": {
    "leader": "ctrl+x",
    "command_list": "ctrl+p",
    "theme_list": "<leader>t",
    "sidebar_toggle": "<leader>b",
    "status_view": "<leader>s",
    "tips_toggle": "<leader>h",
    "scrollbar_toggle": "none",
    "username_toggle": "none",
    "variant_list": "none",
    "display_thinking": "none"
  },
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto",
  "mouse": true
}
