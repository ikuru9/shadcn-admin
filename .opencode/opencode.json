{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "frontend": {
      "description": "화면, 컴포넌트, 상호작용, 스타일을 구현한다.",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "prompt": "{file:./agents/frontend.md}",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "integrator": {
      "description": "API 클라이언트, 상태 관리, 폼/검증, 서버 연동을 연결한다.",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "prompt": "{file:./agents/integrator.md}",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "orchestrator": {
      "description": "요청을 분해하고, `frontend`, `integrator`, `qa` 작업을 순서대로 배치한다.",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/orchestrator.md}",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "qa": {
      "description": "구현 결과를 기능, 타입, 렌더링, 경계면 기준으로 검증한다.",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agents/qa.md}",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  }
}
